{
    "name":  "toprak-gayrimenkul",
    "version":  "1.3.0",
    "description":  "Toprak Gayrimenkul Finansal Yonetim Paneli",
    "main":  "main.js",
    "author":  "Toprak Gayrimenkul",
    "license":  "ISC",
    "dependencies":  {
                         "@electron/rebuild":  "^4.1.0",
                         "better-sqlite3":  "^12.11.1",
                         "electron-updater":  "^6.8.9"
                     },
    "devDependencies":  {
                            "electron":  "^43.0.0",
                            "electron-builder":  "^25.0.0",
                            "node-gyp":  "^13.0.1",
                            "sharp":  "^0.35.3"
                        },
    "scripts":  {
                    "start":  "electron .",
                    "build":  "electron-builder",
                    "build:win":  "electron-builder --win",
                    "postinstall":  "cmd /c rebuild-native.cmd"
                },
    "build":  {
                  "appId":  "com.toprak.gayrimenkul",
                  "productName":  "Toprak Gayrimenkul",
                  "directories":  {
                                      "output":  "dist"
                                  },
                  "files":  [
                                "main.js",
                                "preload.js",
                                "renderer/**/*",
                                "db/**/*",
                                "assets/**/*",
                                "node_modules/**/*"
                            ],
                  "asar":  true,
                  "icon":  "assets/icon.ico",
                  "win":  {
                              "target":  [
                                             {
                                                 "target":  "nsis",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ],
                              "icon":  "assets/icon.ico"
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "perMachine":  false,
                               "allowToChangeInstallationDirectory":  false,
                               "createDesktopShortcut":  "always",
                               "createStartMenuShortcut":  true,
                               "shortcutName":  "Toprak Gayrimenkul",
                               "installerIcon":  "assets/icon.ico",
                               "uninstallerIcon":  "assets/icon.ico",
                               "installerHeaderIcon":  "assets/icon.ico",
                               "license":  null,
                               "unicode":  true,
                               "runAfterFinish":  true,
                               "deleteAppDataOnUninstall":  true
                           },
                   "publish":  [
                                   {
                                       "provider":  "github",
                                       "owner":  "replitorge-lang",
                                       "repo":  "toprak-gayrimenkul"
                                   }
                               ]
              },
    "allowScripts":  {
                         "better-sqlite3@12.11.1":  true,
                         "node-gyp@13.0.1":  true
                     }
}
